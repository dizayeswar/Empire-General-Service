      "id": "id_1046",
      "type": "text",
      "x": 512,
      "y": 440,
      "width": 436,
      "height": 200,
      "text": "Office Portal — other asaas users\nLogin → Office UI (#asaasOfficeApp)\nView all items + filter/search\nAnalytics + Excel/HTML export\nView item details — READ ONLY\nCannot mark returns\nLogout: no password",
      "originalText": "Office Portal — other asaas users\nLogin → Office UI (#asaasOfficeApp)\nView all items + filter/search\nAnalytics + Excel/HTML export\nView item details — READ ONLY\nCannot mark returns\nLogout: no password",
      "fontSize": 16,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "id_1045",
      "lineHeight": 1.25
    },
