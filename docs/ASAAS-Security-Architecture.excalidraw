      "id": "id_1058",
      "type": "text",
      "x": 52,
      "y": 850,
      "width": 896,
      "height": 100,
      "text": "Item Lifecycle\nIN WAREHOUSE (corridor photo) → optional STICKER (photo2, guard only) → RETURNED (signed paper, guard only) → LOCKED\nReference: A# sequential | Location: WW-building-floor-apartment | Status: in_warehouse | returned",
      "originalText": "Item Lifecycle\nIN WAREHOUSE (corridor photo) → optional STICKER (photo2, guard only) → RETURNED (signed paper, guard only) → LOCKED\nReference: A# sequential | Location: WW-building-floor-apartment | Status: in_warehouse | returned",
      "fontSize": 16,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "id_1057",
      "lineHeight": 1.25
    },
