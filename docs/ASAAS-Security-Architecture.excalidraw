      "id": "id_1052",
      "type": "text",
      "x": 52,
      "y": 690,
      "width": 896,
      "height": 110,
      "text": "Authentication & Session\nLogin: verifyLogin → Users sheet (plaintext password) → UUID token in Tokens sheet + localStorage\nEvery API: verifyToken checks dept=asaas, expiry, password digest\nGuard-only server checks: updateAsaasItem + markAsaasReturned → username must be asaas_guard1\nSensitive API gap: addAsaasItem / delete / clear — any valid asaas token (review!)",
      "originalText": "Authentication & Session\nLogin: verifyLogin → Users sheet (plaintext password) → UUID token in Tokens sheet + localStorage\nEvery API: verifyToken checks dept=asaas, expiry, password digest\nGuard-only server checks: updateAsaasItem + markAsaasReturned → username must be asaas_guard1\nSensitive API gap: addAsaasItem / delete / clear — any valid asaas token (review!)",
      "fontSize": 16,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "id_1051",
      "lineHeight": 1.25
    },
